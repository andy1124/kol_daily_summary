---
interface Props {
  name: string;
  slug: string;
  coverImage?: string;
  episodeCount: number;
}
const { name, slug, coverImage, episodeCount } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<a href={`${base}/podcasts/${slug}/`} class="podcast-card">
  <div class="cover">
    {coverImage
      ? <img src={coverImage} alt={name} loading="lazy" />
      : <div class="cover-placeholder">{name.charAt(0)}</div>
    }
  </div>
  <div class="info">
    <span class="name">{name}</span>
    <span class="count">{episodeCount} 集</span>
  </div>
</a>

<style>
  .podcast-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s, transform 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .podcast-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .cover {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--surface2);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--surface2);
  }
  .info {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }
  .count {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
