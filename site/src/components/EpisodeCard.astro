---
interface Props {
  id: string;
  podcastName: string;
  podcastSlug: string;
  title: string;
  publishedAt: string;
  durationSeconds: number;
  coverImage?: string;
  hasMarkdown?: boolean;
}
const {
  id, podcastName, podcastSlug, title, publishedAt,
  durationSeconds, coverImage, hasMarkdown,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const date = new Date(publishedAt).toLocaleDateString("zh-TW", {
  year: "numeric", month: "2-digit", day: "2-digit",
});
const mins = Math.round(durationSeconds / 60);
---
<a href={`${base}/episodes/${id}/`} class="episode-card">
  {coverImage && <img class="thumb" src={coverImage} alt={title} loading="lazy" />}
  <div class="body">
    <div class="meta">
      <span class="podcast">{podcastName}</span>
      <span class="date">{date}</span>
      {mins > 0 && <span class="dur">{mins} 分鐘</span>}
      {hasMarkdown
        ? <span class="badge badge--has">✦ 已摘要</span>
        : <span class="badge badge--none">摘要尚未產出</span>
      }
    </div>
    <div class="title">{title}</div>
  </div>
</a>

<style>
  .episode-card {
    display: flex;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    box-shadow: 0 1px 3px rgba(15,23,42,0.05);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .episode-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 12px rgba(79,70,229,0.1);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .thumb {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .body { flex: 1; min-width: 0; }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    align-items: center;
    margin-bottom: 0.35rem;
  }
  .podcast { font-size: 0.78rem; color: var(--accent2); font-weight: 600; }
  .date, .dur { font-size: 0.78rem; color: var(--text-muted); }
  .badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .badge--has  { background: #dcfce7; color: #15803d; }
  .badge--none { background: var(--surface2); color: var(--text-muted); }
  .title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
    margin-bottom: 0.3rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
