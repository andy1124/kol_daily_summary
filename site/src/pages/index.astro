---
import Layout from "../layouts/Layout.astro";
import EpisodeCard from "../components/EpisodeCard.astro";
import FeaturedEpisodeCard from "../components/FeaturedEpisodeCard.astro";
import { getLatestPerPodcast, getEpisodesGroupedByDate } from "../lib/data";

const latestPerPodcast = getLatestPerPodcast();
const dateGroups = getEpisodesGroupedByDate();
---
<Layout title="財經精選">
  {latestPerPodcast.length === 0 ? (
    <div class="empty">
      <p>尚無資料。請先執行 <code>python scripts/run_all.py</code> 取得 Podcast 資料。</p>
    </div>
  ) : (
    <>
      <section class="featured-section">
        <h2 class="section-label">各節目最新一集</h2>
        <div class="featured-list">
          {latestPerPodcast.map((ep) => (
            <FeaturedEpisodeCard episode={ep} />
          ))}
        </div>
      </section>

      {dateGroups.length > 0 && (
        <section class="history-section">
          {dateGroups.map((group) => (
            <div class="date-group">
              <h2 class="date-header">
                <span class="date-label">{group.label}</span>
                <span class="date-count">{group.episodes.length} 集</span>
              </h2>
              <div class="episode-list">
                {group.episodes.map((ep) => (
                  <EpisodeCard
                    id={ep.id}
                    podcastName={ep.podcast_name}
                    podcastSlug={ep.podcast_slug}
                    title={ep.title}
                    publishedAt={ep.published_at}
                    durationSeconds={ep.duration_seconds}
                    coverImage={ep.cover_image}
                    oneLineSummary={ep.summary?.one_line_summary}
                    marketSentiment={ep.summary?.market_sentiment}
                  />
                ))}
              </div>
            </div>
          ))}
        </section>
      )}
    </>
  )}
</Layout>

<style>
  .featured-section { margin-bottom: 3rem; }
  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }
  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .history-section { margin-top: 1rem; }
  .date-group { margin-bottom: 2.25rem; }
  .date-header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0 0 0.9rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }
  .date-label {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .date-count {
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .episode-list { display: flex; flex-direction: column; gap: 0.65rem; }
  .empty {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 3rem;
    text-align: center;
    color: var(--text-muted);
  }
  .empty code {
    background: var(--surface2);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-family: monospace;
    color: var(--accent2);
  }
</style>
