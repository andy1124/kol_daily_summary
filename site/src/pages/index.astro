---
import Layout from "../layouts/Layout.astro";
import EpisodeCard from "../components/EpisodeCard.astro";
import { getPodcastList, getEpisodesByPodcast } from "../lib/data";

const podcasts = getPodcastList();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout title="財經精選">
  {podcasts.length === 0 ? (
    <div class="empty">
      <p>尚無資料。請先執行 <code>python scripts/run_all.py</code> 取得 Podcast 資料。</p>
    </div>
  ) : (
    <div class="channels">
      {podcasts.map((podcast) => {
        const episodes = getEpisodesByPodcast(podcast.slug);
        return (
          <section class="channel-section">
            <div class="channel-header">
              <div class="channel-title-row">
                {podcast.coverImage && (
                  <img class="channel-cover" src={podcast.coverImage} alt={podcast.name} />
                )}
                <div>
                  <h2 class="channel-name">{podcast.name}</h2>
                  <span class="channel-count">{episodes.length} 集</span>
                </div>
              </div>
              <a href={`${base}/podcasts/${podcast.slug}/`} class="view-all">查看全部 →</a>
            </div>
            <div class="episode-list">
              {episodes.map((ep) => (
                <EpisodeCard
                  id={ep.id}
                  podcastName={ep.podcast_name}
                  podcastSlug={ep.podcast_slug}
                  title={ep.title}
                  publishedAt={ep.published_at}
                  durationSeconds={ep.duration_seconds}
                  coverImage={ep.cover_image}
                  hasMarkdown={ep.hasMarkdown}
                />
              ))}
            </div>
          </section>
        );
      })}
    </div>
  )}
</Layout>

<style>
  .channels { display: flex; flex-direction: column; gap: 2.5rem; }
  .channel-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgba(15,23,42,0.05);
  }
  .channel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.1rem;
    padding-bottom: 0.9rem;
    border-bottom: 2px solid var(--border);
    gap: 1rem;
    flex-wrap: wrap;
  }
  .channel-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .channel-cover {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .channel-name {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.1rem;
    color: var(--text);
  }
  .channel-count {
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .view-all {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent2);
    white-space: nowrap;
  }
  .view-all:hover { text-decoration: underline; }
  .episode-list { display: flex; flex-direction: column; gap: 0.55rem; }
  .empty {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 3rem;
    text-align: center;
    color: var(--text-muted);
  }
  .empty code {
    background: var(--surface2);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-family: monospace;
    color: var(--accent2);
  }
</style>
