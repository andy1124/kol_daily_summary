---
import Layout from "../../layouts/Layout.astro";
import PodcastCard from "../../components/PodcastCard.astro";
import { getPodcastList } from "../../lib/data";

const podcasts = getPodcastList();
---
<Layout title="Podcasts">
  <div class="header">
    <h1>訂閱節目</h1>
    <p class="sub">追蹤中的財經 Podcast，點擊查看各集摘要</p>
  </div>

  {podcasts.length === 0 ? (
    <div class="empty">
      <p>尚無資料。請先執行 <code>python scripts/run_all.py</code> 取得資料。</p>
    </div>
  ) : (
    <div class="grid">
      {podcasts.map((p) => (
        <PodcastCard
          name={p.name}
          slug={p.slug}
          coverImage={p.coverImage}
          episodeCount={p.episodeCount}
        />
      ))}
    </div>
  )}
</Layout>

<style>
  .header { margin-bottom: 2.5rem; }
  h1 { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.04em; margin: 0 0 0.4rem; }
  .sub { color: var(--text-muted); margin: 0; font-size: 0.9rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.25rem;
  }
  .empty {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 3rem;
    text-align: center;
    color: var(--text-muted);
  }
  .empty code {
    background: var(--surface2);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-family: monospace;
    color: var(--accent2);
  }
</style>
