---
import Layout from "../../layouts/Layout.astro";
import { getPodcastList } from "../../lib/data";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const podcasts = getPodcastList();
---
<Layout title="所有頻道">
  <div class="page-header">
    <h1>所有頻道</h1>
    <p class="sub">目前追蹤中的 {podcasts.length} 個財經 Podcast</p>
  </div>
  {podcasts.length === 0 && (
    <div class="empty-state"><p>尚無資料。請先執行 <code>python scripts/run_all.py</code> 取得資料。</p></div>
  )}
  {podcasts.length !== 0 && (
    <div class="kol-list">
      {podcasts.map((p) => (
        <a href={`${base}/podcasts/${p.slug}/`} class="kol-card">
          <div class="kol-cover">
            {p.coverImage && <img src={p.coverImage} alt={p.name} loading="lazy" />}
            {!p.coverImage && <div class="kol-placeholder">{p.name.charAt(0)}</div>}
          </div>
          <div class="kol-info">
            <div class="kol-name">{p.name}</div>
            <div class="kol-count">{p.episodeCount} 集收錄</div>
          </div>
          <div class="kol-arrow">→</div>
        </a>
      ))}
    </div>
  )}
</Layout>
<style>
  .page-header{margin-bottom:1.75rem;padding-bottom:1.25rem;border-bottom:1px solid var(--border)}
  h1{font-size:1.6rem;font-weight:900;letter-spacing:-0.03em;color:var(--text);margin-bottom:0.3rem}
  .sub{font-size:0.82rem;color:var(--text-muted)}
  .kol-list{display:flex;flex-direction:column;gap:0.65rem}
  .kol-card{display:flex;align-items:center;gap:0.9rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:0.9rem 1.1rem;text-decoration:none;color:var(--text);transition:border-color 0.13s,background 0.13s}
  .kol-card:hover{border-color:var(--accent);background:var(--surface2);text-decoration:none}
  .kol-cover{width:52px;height:52px;border-radius:10px;overflow:hidden;flex-shrink:0;background:var(--surface2)}
  .kol-cover img{width:100%;height:100%;object-fit:cover}
  .kol-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:var(--accent)}
  .kol-info{flex:1}
  .kol-name{font-size:0.92rem;font-weight:700}
  .kol-count{font-size:0.76rem;color:var(--text-muted);margin-top:0.1rem}
  .kol-arrow{color:var(--text-muted)}
  .empty-state{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem;text-align:center;color:var(--text-muted);font-size:0.88rem}
  .empty-state code{background:var(--surface2);padding:0.2rem 0.5rem;border-radius:4px;font-family:monospace;color:var(--accent2)}
</style>
