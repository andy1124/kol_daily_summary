---
import Layout from "../../../../layouts/Layout.astro";
import EpisodeCard from "../../../../components/EpisodeCard.astro";
import { getPodcastList, getEpisodesByPodcast } from "../../../../lib/data";

export async function getStaticPaths() {
  const PAGE_SIZE = 20;
  const podcasts = getPodcastList();
  const paths: { params: { slug: string; page: string } }[] = [];
  for (const podcast of podcasts) {
    const episodes = getEpisodesByPodcast(podcast.slug);
    const totalPages = Math.ceil(episodes.length / PAGE_SIZE);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({ params: { slug: podcast.slug, page: String(page) } });
    }
  }
  return paths;
}

const PAGE_SIZE = 20;
const { slug, page: pageParam } = Astro.params;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPage = parseInt(pageParam, 10);
const allEpisodes = getEpisodesByPodcast(slug);
const podcast = getPodcastList().find((p) => p.slug === slug);
const totalPages = Math.max(1, Math.ceil(allEpisodes.length / PAGE_SIZE));
const episodes = allEpisodes.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);
const summarizedCount = allEpisodes.filter((e) => e.hasMarkdown).length;
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
function pageUrl(page: number) {
  return page === 1
    ? `${base}/podcasts/${slug}/`
    : `${base}/podcasts/${slug}/page/${page}/`;
}
---
<Layout title={`${podcast?.name ?? slug} · 第 ${currentPage} 頁`}>
  <div class="podcast-header">
    <div class="podcast-identity">
      <div class="podcast-cover">
        {podcast?.coverImage
          ? <img src={podcast.coverImage} alt={podcast.name} />
          : <div class="cover-placeholder">{(podcast?.name ?? slug).charAt(0)}</div>
        }
      </div>
      <div class="podcast-info">
        <h1 class="podcast-name">{podcast?.name ?? slug}</h1>
        <div class="podcast-meta">
          <span>{allEpisodes.length} 集收錄</span>
          <span class="dot">·</span>
          <span class="summarized">{summarizedCount} 集已摘要</span>
          <span class="dot">·</span>
          <span>第 {currentPage} / {totalPages} 頁</span>
        </div>
      </div>
    </div>
  </div>
  <div class="episode-list">
    {episodes.map((ep) => (
      <EpisodeCard id={ep.id} podcastName={ep.podcast_name} podcastSlug={ep.podcast_slug} title={ep.title} publishedAt={ep.published_at} durationSeconds={ep.duration_seconds} coverImage={ep.cover_image} hasMarkdown={ep.hasMarkdown} hidePodcast={true} />
    ))}
  </div>
  <nav class="pagination">
    <a href={pageUrl(currentPage - 1)} class={hasPrev ? "page-btn" : "page-btn disabled"}>← 上一頁</a>
    <div class="page-numbers">
      {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
        <a href={pageUrl(page)} class={page === currentPage ? "page-num active" : "page-num"}>{page}</a>
      ))}
    </div>
    <a href={pageUrl(currentPage + 1)} class={hasNext ? "page-btn" : "page-btn disabled"}>下一頁 →</a>
  </nav>
</Layout>
<style>
  .podcast-header { margin-bottom: 1.75rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .podcast-identity { display: flex; align-items: center; gap: 1.1rem; }
  .podcast-cover { width: 72px; height: 72px; border-radius: 14px; overflow: hidden; flex-shrink: 0; background: var(--surface2); }
  .podcast-cover img { width: 100%; height: 100%; object-fit: cover; }
  .cover-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; font-weight: 700; color: var(--accent); }
  .podcast-name { font-size: 1.5rem; font-weight: 900; letter-spacing: -0.03em; color: var(--text); margin-bottom: 0.3rem; line-height: 1.2; }
  .podcast-meta { display: flex; gap: 0.5rem; align-items: center; font-size: 0.8rem; color: var(--text-muted); flex-wrap: wrap; }
  .dot { opacity: 0.4; }
  .summarized { color: var(--green); }
  .episode-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .pagination { display: flex; align-items: center; justify-content: space-between; margin-top: 1.75rem; gap: 1rem; flex-wrap: wrap; }
  .page-numbers { display: flex; gap: 0.35rem; flex-wrap: wrap; justify-content: center; }
  .page-num { display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 8px; font-size: 0.82rem; font-weight: 600; color: var(--text-dim); background: var(--surface); border: 1px solid var(--border); text-decoration: none; transition: background 0.13s, color 0.13s; }
  .page-num:hover { background: var(--surface2); color: var(--text); text-decoration: none; }
  .page-num.active { background: var(--accent-dim); border-color: rgba(79,142,247,0.35); color: var(--accent2); }
  .page-btn { font-size: 0.8rem; font-weight: 600; color: var(--text-dim); text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 8px; background: var(--surface); border: 1px solid var(--border); transition: background 0.13s, color 0.13s; }
  .page-btn:hover { background: var(--surface2); color: var(--text); text-decoration: none; }
  .page-btn.disabled { opacity: 0.35; pointer-events: none; }
</style>
